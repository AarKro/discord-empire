{
  "name": "discord-empire",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty && tsc -p scripts/tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "TEST_DATABASE_URL=\"${TEST_DATABASE_URL:-postgres://empire:empire@localhost:5432/empire_test}\" vitest run integration",
    "build": "tsc -b",
    "start": "scripts/with-env.sh scripts/start.sh",
    "stop": "scripts/compose.sh down",
    "world:init": "pnpm build && scripts/with-env.sh pnpm exec tsx scripts/world-init.ts --force",
    "db:generate": "pnpm --filter @empire/db db:generate",
    "db:migrate": "pnpm --filter @empire/db db:migrate"
  },
  "devDependencies": {
    "@empire/content-schemas": "workspace:^",
    "@empire/core": "workspace:^",
    "@empire/db": "workspace:^",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "tsx": "^4.23.1",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
