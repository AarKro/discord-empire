# Forward-only migration runner (tech spec §CI/CD). Runs before app containers.
FROM node:20-bookworm-slim
ENV PNPM_HOME=/pnpm
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable
WORKDIR /app
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* tsconfig.base.json tsconfig.json ./
COPY packages ./packages
RUN pnpm install --frozen-lockfile=false --filter @empire/db...
WORKDIR /app/packages/db
CMD ["pnpm", "exec", "drizzle-kit", "migrate"]
